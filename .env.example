# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=iptv_sync

# IPTV API Credentials
IPTV_BASE_URL=http://your-iptv-server.com:8880
IPTV_USER=your_username
IPTV_PASS=your_password

# Paths
USB_MOUNT_PATH=/media/usb
ARCHIVE_PATH=/home/your_user/Archivos_IPTV

# Scheduler timezone for "1 AM" runs (e.g. America/Bogota, America/Mexico_City, UTC)
SCHEDULE_TIMEZONE=UTC

# Download workers and resiliency
MAX_CONCURRENT_DOWNLOADS=3
DOWNLOAD_STALL_TIMEOUT_SECONDS=180
DOWNLOAD_MAX_AUTO_RETRIES=6
DOWNLOAD_RETRY_BASE_SECONDS=5
DOWNLOAD_RETRY_MAX_SECONDS=120
DOWNLOAD_CONNECT_TIMEOUT_SECONDS=15
DOWNLOAD_READ_TIMEOUT_SECONDS=45
DOWNLOAD_PROGRESS_COMMIT_INTERVAL_SECONDS=2
